{
  "name": "armila-design-studio",
  "version": "1.0.0",
  "description": "Armila Design Studio — architecture & interior design portfolio website",
  "private": true,
  "scripts": {
    "build:html": "node build.js",
    "build:css": "tailwindcss -i ./css/input.css -o ./css/style.css --minify",
    "build": "npm run build:html && npm run build:css",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/style.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "lenis": "^1.3.23"
  }
}
